pipeline {
    agent any

    stages {
        stage('User Details') {
            steps {
                sh '''
                echo "Current logged-in user"
                whoami

                echo "Current user's full details"
                id

                echo "Checking ubuntu user (if exists) and listing their details"
                id ubuntu || echo "ubuntu user not found"

                echo "Checking jenkins user (if exists) and listing their details"
                id jenkins || echo "jenkins user not found"
            
                echo "Checking docker user (if exists) and listing their details"
                id docker || echo "docker user not found"
                '''
            }
        }
    }
}
